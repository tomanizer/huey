# .env.example – safe template for QueryService environment variables.
# Copy this file to .env and fill in values for your local setup.
# Never commit .env or any file containing real credentials.
# See docs/server/configuration-reference.md for full details.

# ---------------------------------------------------------------------------
# Core Server
# ---------------------------------------------------------------------------
QUERYSERVICE_HOST=0.0.0.0
QUERYSERVICE_PORT=8000
QUERYSERVICE_LOG_LEVEL=INFO
QUERYSERVICE_LOG_FORMAT=text
# Comma-separated or JSON array of allowed browser origins, e.g.:
# QUERYSERVICE_CORS_ORIGINS=http://localhost:5173

# ---------------------------------------------------------------------------
# Dataset and Seeding
# ---------------------------------------------------------------------------
# QUERYSERVICE_DATASETS_CONFIG_PATH=server/datasets_config/datasets.yaml
QUERYSERVICE_SEED_SAMPLE_DATA=false
QUERYSERVICE_SCHEMA_CACHE_TTL_SECONDS=300

# ---------------------------------------------------------------------------
# DuckDB Runtime
# ---------------------------------------------------------------------------
# QUERYSERVICE_DATA_DIR=/path/to/duckdb.db   # unset = in-memory
# QUERYSERVICE_DUCKDB_THREADS=4
# QUERYSERVICE_DUCKDB_MEMORY_LIMIT=8GB
QUERYSERVICE_DUCKDB_TEMP_DIRECTORY=/tmp/huey-duckdb-tmp
QUERYSERVICE_DUCKDB_ENABLE_OBJECT_CACHE=true

# ---------------------------------------------------------------------------
# Query and Response Limits
# ---------------------------------------------------------------------------
QUERYSERVICE_QUERY_TIMEOUT_SECONDS=30.0
QUERYSERVICE_MAX_CONCURRENT_QUERIES=8
QUERYSERVICE_MAX_QUERY_QUEUE_DEPTH=32
QUERYSERVICE_SHUTDOWN_DRAIN_SECONDS=10.0
QUERYSERVICE_TUPLES_DEFAULT_LIMIT=200
QUERYSERVICE_PICKLIST_DEFAULT_LIMIT=100
QUERYSERVICE_MAX_CELLS_PER_RESPONSE=10000
QUERYSERVICE_MAX_AXIS_CARDINALITY=5000

# ---------------------------------------------------------------------------
# Authentication and Rate Limiting
# ⚠️  Set QUERYSERVICE_API_KEYS in .env (never commit real keys here).
# ---------------------------------------------------------------------------
QUERYSERVICE_AUTH_ENABLED=false
# QUERYSERVICE_API_KEYS=replace-with-real-key1,replace-with-real-key2
QUERYSERVICE_RATE_LIMIT_ENABLED=false
QUERYSERVICE_RATE_LIMIT_QUERY=100/minute
QUERYSERVICE_RATE_LIMIT_EXPORT=10/minute
QUERYSERVICE_RATE_LIMIT_BY_API_KEY=true
QUERYSERVICE_TRUSTED_PROXY_COUNT=0

# ---------------------------------------------------------------------------
# Export Pipeline
# ---------------------------------------------------------------------------
QUERYSERVICE_EXPORT_TTL_SECONDS=3600
QUERYSERVICE_EXPORT_MAX_CONCURRENT=5
QUERYSERVICE_EXPORT_OUTPUT_DIR=/tmp/huey-exports
QUERYSERVICE_EXPORT_DB_PATH=/tmp/huey-exports/jobs.db

# ---------------------------------------------------------------------------
# Query Result Cache
# ---------------------------------------------------------------------------
QUERYSERVICE_CACHE_ENABLED=false
QUERYSERVICE_CACHE_TTL_SECONDS=120
QUERYSERVICE_CACHE_MAX_BYTES=67108864
QUERYSERVICE_CACHE_MAX_ITEM_BYTES=1048576
QUERYSERVICE_CACHE_ADMISSION_MIN_DURATION_MS=0.0

# ---------------------------------------------------------------------------
# Execution Mode and Partitions
# ---------------------------------------------------------------------------
QUERYSERVICE_EXECUTION_MODE=sample_table
# QUERYSERVICE_PARTITION_BASE_PATH=/data/partitions
# QUERYSERVICE_S3_BUCKET=my-bucket
# QUERYSERVICE_S3_REGION=us-east-1

# ---------------------------------------------------------------------------
# AWS credentials (only needed for S3 partition mode)
# ⚠️  Never put real credentials here; use IAM roles or a secrets manager.
# ---------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
