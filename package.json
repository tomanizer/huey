{
  "name": "huey",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "preinstall": "node scripts/check-node-version.js",
    "dev":       "vite",
    "build":     "vite build",
    "preview":   "vite preview",
    "pretest:unit": "node scripts/check-node-version.js",
    "test:unit": "vitest run",
    "pretest:coverage": "node scripts/check-node-version.js",
    "test:coverage": "vitest run --coverage",
    "pretest:ui": "node scripts/check-node-version.js",
    "test:ui":   "playwright test",
    "perf:ui":   "node scripts/ui_benchmark_runner.cjs",
    "lint:js":   "eslint src/ --max-warnings 47"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.49.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^10.0.2",
    "jsdom": "^24.1.3",
    "serve": "^14.2.5",
    "vite": "^7.3.1",
    "vitest": "^3.0.0"
  }
}
