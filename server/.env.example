# QueryService environment template
# Copy to .env and set as needed (optional; defaults work for local dev)

# Server
# QUERYSERVICE_HOST=0.0.0.0
# QUERYSERVICE_PORT=8000
# QUERYSERVICE_LOG_LEVEL=INFO

# Datasets config path (default: server/datasets_config/datasets.yaml)
# QUERYSERVICE_DATASETS_CONFIG_PATH=/path/to/datasets.yaml

# S3 (for partition read)
# QUERYSERVICE_S3_BUCKET=my-bucket
# QUERYSERVICE_S3_REGION=us-east-1

# AWS credentials (when using S3) – or use IAM role / default chain
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Authentication
# QUERYSERVICE_AUTH_ENABLED=false
# QUERYSERVICE_API_KEYS=key1,key2,key3
